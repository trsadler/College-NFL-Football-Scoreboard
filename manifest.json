{
  "id": "nfl-college-scoreboard",
  "name": "NFL/College Scoreboard",
  "version": "0.1.0",
  "author": "Thomas",
  "description": "Custom NFL/NCAA football scoreboard: team stack with logo/score/timeouts, simulated field with yard lines and ball position indicator. Includes past scores and upcoming games.",
  "entry_point": "manager.py",
  "class_name": "NFLCollegeScoreboardPlugin",
  "category": "sports",
  "tags": ["nfl", "college-football", "football", "sports", "scores"],
  "compatible_versions": [">=2.0.0"],
  "requires": {
    "python": ">=3.9",
    "display_size": {
      "min_width": 128,
      "min_height": 32
    }
  },
  "config_schema": "config_schema.json",
  "requirements_file": "requirements.txt",
  "update_interval": 15,
  "default_duration": 15,
  "display_modes": ["nfl_college_live", "nfl_college_recent", "nfl_college_upcoming"],
  "api_requirements": ["ESPN API"]
}
